{"cp":{"body":["use std::io::{self, BufWriter, Read, Write};","","fn main() {","    let mut input = String::new();","","    io::stdin()","        .read_to_string(&mut input)","        .expect(\"Failed to read n\");","","    let mut tokens = input.split_whitespace();","    let mut next = || tokens.next().expect(\"Tokenization error\");","","    let out = io::stdout();","    let mut output = BufWriter::new(out.lock());","","    let t: u32 = next().parse().expect(\"Invalid T\");","","    for _ in 0..t {","        let n: usize = next().parse().expect(\"Invalid N\");","","        let mut a: Vec<i32> = Vec::with_capacity(n);","        for _ in 0..n {","            let val: i32 = next().parse().expect(\"Invalid array element\");","            a.push(val);","        }","","        writeln!(output).expect(\"Error in writing output\");","    }","}"],"prefix":"cp"}}